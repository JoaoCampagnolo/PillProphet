# PillProphet environment configuration

# Data directories (defaults work out of the box)
# DATA_DIR=data
# RAW_DATA_DIR=data/raw
# PROCESSED_DATA_DIR=data/processed

# ClinicalTrials.gov API (no key required for public API, but set base URL if needed)
# CTG_API_BASE_URL=https://clinicaltrials.gov/api/v2

# Logging
# LOG_LEVEL=INFO
